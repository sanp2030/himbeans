# ─── Required ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:localdev@localhost:5432/postgres"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Auth (Vercel) ─────────────────────────────────────────
# AUTH_URL: set to your real production domain in Vercel (used for metadata,
# sitemap, canonical URLs, and OAuth callback construction).
AUTH_URL="https://himbeans.vercel.app"
# trustHost is set in code (src/lib/auth.config.ts) — no env var needed.

# ─── OAuth sign-in (each provider appears on the sign-in page ONLY when its
#     keys are set; email+password sign-in works without any of these) ───────
AUTH_GOOGLE_ID=""        # console.cloud.google.com → OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=""
AUTH_APPLE_ID=""         # developer.apple.com → Services ID
AUTH_APPLE_SECRET=""

# ─── Stripe (sandbox keys from dashboard.stripe.com/test/apikeys) ──
# Without these, "Pay by card" is disabled in checkout — counter & gift card still work.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."   # from: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# ─── Email receipts (resend.com — free tier: 3,000 emails/month) ───
RESEND_API_KEY="re_..."
EMAIL_FROM="HimBean <orders@himbean.coffee>"

# ─── SMS order updates (twilio.com) ────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_FROM="+1..."

# ─── Analytics (each activates only when its key is set) ───
NEXT_PUBLIC_GA4_ID=""          # G-XXXXXXXXXX from analytics.google.com
NEXT_PUBLIC_POSTHOG_KEY=""     # phc_... from posthog.com
NEXT_PUBLIC_POSTHOG_HOST=""    # optional, defaults to https://us.i.posthog.com

# ─── Optional ───────────────────────────────────────────────
SEED_ADMIN_PASSWORD="change-before-launch"  # Admin account password for prisma/seed.ts
PUBLIC_CORS_ORIGINS=""   # comma-separated origins allowed to call the public API,
                          # e.g. "https://your-marketing-site.com"
